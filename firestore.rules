rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'embeddings', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.embeddings is list && data.embeddings.size() > 0 && data.embeddings.size() <= 10 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      // For recognition, we need to list users to compare embeddings
      allow list, get: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      
      // Updates usually not needed for embeddings in this simple flow, but maybe for adding more
      allow update: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) &&
                    incoming().createdAt == resource.data.createdAt;
                    
      allow delete: if false; // Only admin via console for now
    }
  }
}
