{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered user with face embeddings",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "User's full name"
        },
        "face_descriptor": {
          "type": "array",
          "description": "Face embedding (128 floats)",
          "items": {
            "type": "number"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Registration timestamp"
        }
      },
      "required": ["name", "face_descriptor", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance Session",
      "description": "A single attendance session with check-in and check-out times",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "userName": {
          "type": "string"
        },
        "checkInAt": {
          "type": "string",
          "format": "date-time"
        },
        "checkOutAt": {
          "type": "string",
          "format": "date-time"
        },
        "durationHours": {
          "type": "number"
        }
      },
      "required": ["userId", "userName", "checkInAt"]
    }
  },
  "firestore": {
    "/users": {
      "schema": "User",
      "description": "Collection of registered users"
    },
    "/attendance": {
      "schema": "Attendance",
      "description": "Collection of attendance records"
    }
  }
}
