{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered user with face embeddings",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "User's full name"
        },
        "embeddings": {
          "type": "array",
          "description": "Array of face embeddings (Float32Array converted to array)",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Registration timestamp"
        }
      },
      "required": ["name", "embeddings", "createdAt"]
    }
  },
  "firestore": {
    "/users": {
      "schema": "User",
      "description": "Collection of registered users"
    }
  }
}
